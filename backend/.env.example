# Required for AI insights (section scoring + teaching coach)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# JWT Auth (change in production!)
JWT_SECRET=pawsed-dev-secret-change-in-production
JWT_EXPIRE_HOURS=72

# CORS — add your Railway frontend URL in production
# CORS_ORIGINS=http://localhost:5173,https://pawsed-frontend.up.railway.app
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost:8080,http://localhost:4173

# Database — on Railway point this at your volume mount path
# DB_PATH=/data/pawsed.db
DB_PATH=pawsed.db

# Session storage — on Railway point this at your volume mount path
# SESSIONS_DIR=/data/sessions
SESSIONS_DIR=sessions

# Optional overrides
PROCESSING_FPS=5
MAX_UPLOAD_MB=300
MODEL_PATH=models/face_landmarker.task
